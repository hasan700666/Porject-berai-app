{
  "expo": {
    "name": "Berai",
    "slug": "vaseting_app_2",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "BeraiBerai",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo-01.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hasan700666.vaseting_app_2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-01.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash_screen.jpg",
          "resizeMode": "cover",
          "imageWidth": 1000,
          "enableFullScreenImage_legacy": true
        }
      ],
      "@react-native-vector-icons/ionicons"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6c31ae0-90d5-438a-9859-d46f3ebb86d9"
      }
    }
  }
}